# Axis Cloud — env for the ForgeFX sync client. Copy to `.env` and fill in for your own project.
# NEVER commit real values. The publishable/anon key is safe to expose (RLS enforces per-user access);
# the service_role key / DB password / SMTP creds / Patreon client secret are NOT here — keep those in
# the Supabase dashboard and your CI secrets only.

# Your Supabase project URL + publishable (anon) key — from Project Settings → API.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Turn the cloud layer on in ForgeFX (default off — release builds ship dark).
AXIS_CLOUD=1
